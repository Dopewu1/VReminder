<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.VoiceReminder" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/text_primary</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/text_secondary</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/surface_card</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.VoiceReminder.Dialog</item>
    </style>

    <style name="ThemeOverlay.VoiceReminder.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/surface_card</item>
    </style>

    <style name="Widget.VoiceReminder.ActiveIndicator" parent="Widget.Material3.NavigationBar.ActiveIndicator">
        <item name="android:color">@color/surface_base</item>
    </style>
</resources>
